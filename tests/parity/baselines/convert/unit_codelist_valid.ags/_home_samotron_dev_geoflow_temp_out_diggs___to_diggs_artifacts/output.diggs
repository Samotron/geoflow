<?xml version="1.0" encoding="UTF-8"?>
<Diggs xmlns="http://diggsml.org/schemas/2.6" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:gml="http://www.opengis.net/gml">
  <Project>
    <gml:name>P1</gml:name>
  </Project>
  <SamplingLocation>
    <gml:name>BH01</gml:name>
  </SamplingLocation>
  <AttenbergLimits>
    <locationId>BH01</locationId>
    <liquidLimit>45</liquidLimit>
  </AttenbergLimits>
  <MetadataGroup name="UNIT">
    <heading name="UNIT_ABBR" unit="" type="X"/>
    <heading name="UNIT_DESC" unit="" type="X"/>
    <row>
      <field name="UNIT_ABBR">m</field>
      <field name="UNIT_DESC">metres</field>
    </row>
    <row>
      <field name="UNIT_ABBR">kN/m2</field>
      <field name="UNIT_DESC">kilonewtons per square metre</field>
    </row>
  </MetadataGroup>
  <DataGroup name="TRAN">
    <heading name="TRAN_AGS" unit="" type="X"/>
    <row>
      <field name="TRAN_AGS">4.1</field>
    </row>
  </DataGroup>
</Diggs>