{
  "name": "geoflow",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dep:age": "tsx scripts/check-dep-age.ts",
    "parity:capture": "tsx scripts/capture-rust-baselines.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.7.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.12.0",
    "fast-check": "^4.8.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.1",
    "yaml": "^2.5.1"
  }
}
